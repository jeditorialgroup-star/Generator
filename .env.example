# ─────────────────────────────────────────────────────────────────────────────
# .env.example — inforeparto.com Content Pipeline
# Copia este archivo a ~/.env.projects y rellena los valores reales.
# NUNCA subas el archivo con valores reales a ningún repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM ──────────────────────────────────────────────────────────────────────
# Anthropic Claude — https://console.anthropic.com/settings/keys
export ANTHROPIC_API_KEY=sk-ant-...

# ── Búsqueda y fuentes ───────────────────────────────────────────────────────
# Serper.dev (Google Search API) — https://serper.dev/api-key
export SERPER_API_KEY=...

# Jina AI Reader (verificación de URLs) — https://jina.ai/reader/
export JINA_API_KEY=jina_...

# ── Imágenes ──────────────────────────────────────────────────────────────────
# Pexels API — https://www.pexels.com/api/new/
export PEXELS_API_KEY=...

# ── WordPress REST API — inforeparto.com ──────────────────────────────────────
# Usuario WP con rol Editor o Administrator
export WP_INFOREPARTO_USER=nombre-usuario-wp
# App Password generado en WP → Usuarios → Perfil → Contraseñas de aplicación
# Formato con espacios: "xxxx xxxx xxxx xxxx xxxx xxxx"
export WP_INFOREPARTO_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
# URL base de la REST API
export WP_INFOREPARTO_URL=https://inforeparto.com/wp-json/wp/v2

# ── WordPress REST API — psicoprotego.es (si aplica) ─────────────────────────
export WP_PSICOPROTEGO_USER=nombre-usuario-wp
export WP_PSICOPROTEGO_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
export WP_PSICOPROTEGO_URL=https://psicoprotego.es/wp-json/wp/v2

# ── MariaDB ───────────────────────────────────────────────────────────────────
# Contraseña de wp_user en MariaDB
# (el host, usuario y nombre de BD están configurados en los scripts)
export WP_DB_PASSWORD=...
# Para psicoprotego (si aplica)
export WP_PSICO_DB_PASSWORD=...

# ── Telegram ──────────────────────────────────────────────────────────────────
# Bot principal (Claude Code bot / autopublisher) — @BotFather para crear
export IR_TELEGRAM_BOT_TOKEN=0000000000:AAF...
export IR_TELEGRAM_CHAT_ID=0000000000

# ── Google APIs ───────────────────────────────────────────────────────────────
# Service account JSON para GSC + Indexing API
# Archivo: /home/devops/.credentials/gsc-serviceaccount.json
# (no se pasa como variable, se referencia por ruta en los scripts)

# ── Embeddings locales (Ollama) ───────────────────────────────────────────────
# URL de la instancia de Ollama (default: http://localhost:11434)
export OLLAMA_URL=http://localhost:11434

# ── MariaDB (legacy vars, usadas por algunos scripts) ────────────────────────
export MYSQL_WP_DB=wordpress_db
export MYSQL_PSICO_DB=wp_psicoprotego
